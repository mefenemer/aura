# scripts/dev-issue-fixer.env.example
# Config for the always-on "Pass to Developer" AI auto-fix watcher.
# Copy this to `.env.handoff` (gitignored) and fill in the values, then load the
# launchd service:  launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.aura.issue-fixer.plist
#
# The watcher (scripts/dev-issue-fixer.mjs) polls AURA_BASE_URL for queued issues,
# fixes them with the Claude Code CLI, and opens a PR with gh.

# The deploy whose issue queue to watch. Must be the environment where issues are
# raised + handed off. Verify this matches your actual Netlify staging branch-deploy URL.
AURA_BASE_URL=https://staging--bemoreswan.netlify.app

# Shared secret — MUST be byte-for-byte identical to the DEV_HANDOFF_TOKEN env var
# set on the Netlify deployment above. If it's unset on Netlify, the endpoint is a
# 503 and nothing can be claimed.
DEV_HANDOFF_TOKEN=

# Branch fixes are forked from / PRs target. Default: staging.
BASE_BRANCH=staging

# Idle poll cadence in ms (default 15000).
POLL_INTERVAL_MS=15000
